#MISC

theme = TokyoNight
title = "Ghostty"
focus-follows-mouse
confirm-close-surface = true
quit-after-last-window-closed = true
shell-integration = detect
shell-integration-features = true
desktop-notifications = true
undo-timeout = 5s
fullscreen= false

######################################################################
# KEYMAP
######################################################################
keybind = clear
#CLIPBOARD
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+alt+v=paste_from_selection
#FONT SIZE
keybind = ctrl+==increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size
keybind = ctrl+a=select_all
#SCROLL
keybind = ctrl+home=scroll_to_top
keybind = ctrl+end=scroll_to_bottom
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = alt+up=scroll_page_lines:-3
keybind = alt+down=scroll_page_lines:3
#SELECT TEXT
# keybind = shift+down=adjust_selection:down
# keybind = shift+left=adjust_selection:left
# keybind = shift+right=adjust_selection:right
# keybind = shift+up=adjust_selection:up
# keybind = shift+home=adjust_selection:beginning_of_line
# keybind = shift+end=adjust_selection:end_of_line
#WINDOW
keybind = alt+space>n=new_window
keybind = alt+w=close_window
keybind = alt+space>ctrl+w=close_all_windows

keybind = F11=toggle_fullscreen
keybind = F10=toggle_window_decorations
#keybind = F7=toggle_window_float_on_top

keybind = alt+space>0=reset_window_size
keybind = alt+space>x=close_surface

keybind = alt+t=new_tab
keybind = alt+space>w=close_tab
keybind = alt+,=previous_tab
keybind = alt+.=next_tab

keybind = alt+shift+,=move_tab:-1
keybind = alt+shift+.=move_tab:1

keybind = alt+space>left=new_split:left
keybind = alt+space>down=new_split:down
keybind = alt+space>up=new_split:up
keybind = alt+space>right=new_split:right

keybind = alt+space>h=goto_split:left
keybind = alt+space>j=goto_split:down
keybind = alt+space>k=goto_split:up
keybind = alt+space>l=goto_split:right

keybind = alt+space>F5=reload_config
keybind = alt+space>e=open_config
#MISC
keybind = ctrl+space=toggle_command_palette
keybind = ctrl+`=toggle_quick_terminal
keybind = alt+space>u=undo
